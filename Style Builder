«Мир завтрашнего дня» из прошлого."}, {"id": "grunge", "name": "Grunge", "cat": "Retro", "desc": "Гранж 90-х: грязные текстуры, рваные края, приглушённые цвета, печатная машинка Special Elite, потёртость. Сыро, бунтарски, «андеграунд»."}, {"id": "punkzine", "name": "Punk Zine / DIY", "cat": "Retro", "desc": "Панк-зин: чёрно-белая ксерокопия, «письмо из вырезок», скотч, рваная бумага, кривые наклоны. Агрессивный DIY-протест, ноль гламура."}, {"id": "cyberpunk", "name": "Cyberpunk Neon", "cat": "Sci-Fi / Tech", "desc": "Киберпанк (Night City): почти чёрный фон, неон жёлтый/маджента/циан, глитч-акценты, скан-линии, «хай-тек+грязь». Топ для геймерского магаза."}, {"id": "scifi", "name": "Sci-Fi Hi-Tech HUD", "cat": "Sci-Fi / Tech", "desc": "Sci-fi интерфейс (Mass Effect/Tron): глубокий синий, срезанные углы (clip-path), светящиеся линии, Oswald. Технологично и «дорого по-космически»."}, {"id": "hud", "name": "FPV OSD / Telemetry HUD", "cat": "Sci-Fi / Tech", "desc": "Телеметрия как в FPV-дроне/прицеле: чёрный фон, янтарно-зелёный моноширинный текст, перекрестия, пунктирные рамки, «данные на экране»."}, {"id": "terminal", "name": "Terminal / Code IDE", "cat": "Sci-Fi / Tech", "desc": "Редактор кода / консоль: фон VS Code, моноширина, подсветка синтаксиса (зелёный/синий/оранжевый), приглашение $. Для своих, по-программистски."}, {"id": "ascii", "name": "ASCII / Text-mode", "cat": "Sci-Fi / Tech", "desc": "Псевдографика DOS: всё из символов и рамок ╔═╗, зелёный текст на чёрном, никаких изображений — только текст. Хардкорный ретро-терминал."}, {"id": "wireframe", "name": "Wireframe / Blueprint", "cat": "Sci-Fi / Tech", "desc": "Чертёж/прототип: синий «миллиметровый» фон, белые линии, пунктир, подписи-аннотации, моноширина. Намеренно «сырой» лоу-фай макет."}, {"id": "glitch", "name": "Glitch / Datamosh", "cat": "Sci-Fi / Tech", "desc": "Глитч/датамош: RGB-расщепление, сдвиги, цифровой «сбой», блочные артефакты на чёрном. Тревожно и стильно — для хоррор/киберпанк-релизов."}, {"id": "hologram", "name": "Holographic / Iridescent", "cat": "Sci-Fi / Tech", "desc": "Голографик: переливающиеся радужные градиенты, перламутр, глянцевые полупрозрачные панели. Футуристичный «премиум-коллекционное издание»."}, {"id": "pixel", "name": "Pixel Art / 8-bit", "cat": "Gaming", "desc": "Пиксель-арт 8-бит: шрифт Press Start 2P, жёсткие квадратные блоки и тени без сглаживания, ограниченная палитра. Чистая ретро-игровая ностальгия."}, {"id": "gamedark", "name": "Gaming Dark UI (Steam-like)", "cat": "Gaming", "desc": "Тёмный UI как Steam/Discord/Epic: глубокий сине-серый фон, светлый текст, акцент-кнопки, аккуратные карточки. Сразу читается как «игровой магазин»."}, {"id": "esports", "name": "Esports RGB", "cat": "Gaming", "desc": "Киберспорт/геймерское «железо»: чёрный, агрессивные углы, RGB-неон (красный+синий), Rajdhani, резкие скосы и свечение. Турнирная энергия."}, {"id": "fantasy", "name": "Dark Fantasy / RPG", "cat": "Gaming", "desc": "Тёмное фэнтези/RPG: пергамент и тёмное дерево, золотые рамки, готический шрифт, самоцветные акценты. «Инвентарь и свитки» — под RPG и стратегии."}, {"id": "comic", "name": "Comic Book / Pop Art", "cat": "Gaming", "desc": "Комикс/поп-арт: халфтон-точки, толстые чёрные контуры, жёсткие тени, «BANG!»-шрифт, кричащие цвета. Динамично и весело, привлекает взгляд."}, {"id": "steampunk", "name": "Steampunk", "cat": "Gaming", "desc": "Стимпанк: латунь и сепия, шестерёнки, заклёпки, викторианский шрифт, кожа и медь. Тёплый «механический ретро-будущизм» эпохи пара."}, {"id": "dieselpunk", "name": "Dieselpunk / Industrial", "cat": "Gaming", "desc": "Дизельпанк/индустриал: стальные плиты, заклёпки, чёрно-жёлтые предупреждающие полосы, трафаретный шрифт. Военно-промышленная суровость 30-40х."}, {"id": "kawaii", "name": "Kawaii / Cute Pastel", "cat": "Artistic", "desc": "Кавай: пастельный розово-мятный, округлые формы Fredoka, сердечки и звёздочки, мягкие тени, румянец. Милый дружелюбный стиль для казуалок."}, {"id": "cottage", "name": "Cottagecore / Organic", "cat": "Artistic", "desc": "Коттеджкор: тёплый крем и шалфейная зелень, засечки + рукописный акцент, ботаника, мягкость, землистость. Уютный «деревенский» натурализм."}, {"id": "sketch", "name": "Hand-drawn / Sketch", "cat": "Artistic", "desc": "Рисунок от руки: «бумага в клетку», рукописный шрифт, кривоватые рамки и стрелочки, эффект наброска. Тёплый личный вайб, будто черновик в блокноте."}, {"id": "aurora", "name": "Aurora / Gradient Mesh", "cat": "Artistic", "desc": "Современный «градиентный туман»: тёмный фон с размытыми разноцветными пятнами-сиянием, стеклянные карточки. Модно, мягко, технологично-красиво."}, {"id": "liquid", "name": "Liquid / Organic Blob", "cat": "Artistic", "desc": "Органик/жидкие формы: мягкие «капли»-блобы вместо прямоугольников, плавные градиенты, скруглния-разнобой. Дружелюбно, живо, без острых углов."}];
const stage = document.getElementById('stage');
const picker = document.getElementById('picker');
let i = 0;

function render(){
  const t = THEMES[i];
  stage.className = 'stage theme-' + t.id;
  document.getElementById('styleName').textContent = (i+1) + '. ' + t.name;
  document.getElementById('styleCat').textContent = t.cat;
  document.getElementById('styleDesc').textContent = t.desc;
  document.getElementById('counter').textContent =
    String(i+1).padStart(2,'0') + ' / ' + THEMES.length;
  picker.value = i;
  stage.scrollIntoView({behavior:'smooth', block:'nearest'});
}
function go(n){ i = (n + THEMES.length) % THEMES.length; render(); }

document.getElementById('prev').onclick = () => go(i-1);
document.getElementById('next').onclick = () => go(i+1);
picker.onchange = e => go(parseInt(e.target.value,10));
document.addEventListener('keydown', e => {
  if(e.key === 'ArrowLeft') go(i-1);
  if(e.key === 'ArrowRight') go(i+1);
});
render();
</script>
