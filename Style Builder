<script>
const THEMES = [{"id": "material", "name": "Material Design", "cat": "Modern UI", "desc": "Гугловский язык: «бумажные» слои, мягкие многоуровневые тени, один яркий акцент. Привычно и дружелюбно, но выглядит «как у всех»."}, {"id": "neumorph", "name": "Neumorphism", "cat": "Modern UI", "desc": "Мягкий «выдавленный из пластика» UI: один фон, объём через двойные тени (свет+тень). Красиво, но низкий контраст — плохо для торговли (кнопки теряются)."}, {"id": "glass", "name": "Glassmorphism", "cat": "Modern UI", "desc": "Матовое стекло на цветном фоне: размытие, полупрозрачность, тонкая светлая граница. Очень «дорого» смотрится на ярких фонах/обложках игр."}, {"id": "clay", "name": "Claymorphism", "cat": "Modern UI", "desc": "«Пластилиновый» 3D: толстые скруглния, пухлые двойные тени, сочные цвета. Игривый, дружелюбный — заходит для казуальных/детских товаров."}, {"id": "skeuo", "name": "Skeuomorphism", "cat": "Modern UI", "desc": "Старый iOS-стиль: имитация реальных материалов (кожа, металл, стекло), глянцевые градиентные кнопки, фаски. Устарел, но даёт «осязаемость»."}, {"id": "flat", "name": "Flat Design", "cat": "Modern UI", "desc": "Плоско и ярко: никаких теней и градиентов, чистые цветовые блоки, простые формы. Быстро грузится, легко читается, но безлико."}, {"id": "saas", "name": "SaaS / Enterprise", "cat": "Modern UI", "desc": "Корпоративный стандарт 2020-х: белый фон, Inter, аккуратные карточки с тонкой границей, тёмно-синие кнопки, много воздуха. Доверие и «серьёзность»."}, {"id": "bento", "name": "Bento Grid", "cat": "Modern UI", "desc": "Японская «коробочка бенто»: модульная сетка из плиток разного размера со скруглением, мягкими фонами. Очень модный лэндинговый стиль 2024-25."}, {"id": "brutal", "name": "Brutalism (Raw)", "cat": "Bold / Raw", "desc": "Сырой веб-брутализм: системные шрифты/моноширина, чёрные рамки, ноль скруглений и теней, «как есть». Честно, дёшево в разработке, отпугивает массу."}, {"id": "neobrutal", "name": "Neo-Brutalism", "cat": "Bold / Raw", "desc": "Модный «причёсанный брутализм»: толстые чёрные обводки, жёсткие смещённые тени, кислотные цвета. Молодёжно, цепляет, отлично для геймерского магаза."}, {"id": "swiss", "name": "Swiss / Int. Typographic", "cat": "Bold / Raw", "desc": "Швейцарский стиль: строгая сетка, Helvetica, красно-чёрная гамма, крупная типографика, ноль украшений. Дисциплина и читабельность как искусство."}, {"id": "bauhaus", "name": "Bauhaus", "cat": "Bold / Raw", "desc": "Баухаус: чистая геометрия, первичные цвета (красный/синий/жёлтый), круги и прямоугольники, толстый чёрный контур. Дерзко и вне времени."}, {"id": "memphis", "name": "Memphis", "cat": "Bold / Raw", "desc": "Мемфис (80-е): хаотичные геометрические фигуры, зигзаги, кислотные цвета, terrazzo-точки. Весёлый китч — внимание привлекает, но «кричит»."}, {"id": "maximal", "name": "Maximalism", "cat": "Bold / Raw", "desc": "Максимализм: «больше — значит лучше». Много шрифтов, паттернов, цветов и рамок сразу. Перегруз, но запоминается; для смелого арт-направления."}, {"id": "mono", "name": "Minimalist Monochrome", "cat": "Minimal", "desc": "Чёрно-белый минимализм: тонкие линии, лёгкие начертания, максимум воздуха, ничего лишнего. Премиально и спокойно, ставка на типографику и фото."}, {"id": "zen", "name": "Japanese Zen / Muji", "cat": "Minimal", "desc": "Японский дзен / Muji: тёплый небелёный фон, мягкие нейтральные тона, воздух, минимум контраста. Тихо, дорого, «ничего не отвлекает от товара»."}, {"id": "nordic", "name": "Scandinavian / Nordic", "cat": "Minimal", "desc": "Скандинавия / хюгге: светлая прохладная гамма, мягкие пастельные акценты (шалфей, пыльно-голубой), скруглния, уют. Чисто, тепло, дружелюбно."}, {"id": "rams", "name": "Dieter Rams Functional", "cat": "Minimal", "desc": "Функционализм Дитера Рамса (Braun): светло-серый фон, Helvetica, единственный оранжевый акцент, идеальная сетка. «Меньше, но лучше»."}, {"id": "editorial", "name": "Editorial / Magazine", "cat": "Editorial", "desc": "Журнальная вёрстка: