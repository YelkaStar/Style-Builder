<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GameKeys — 50 стилей оформления</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&family=Inter:wght@400;500;600;700;800&family=Nunito:wght@400;700;800;900&family=Comfortaa:wght@400;700&family=Fredoka:wght@400;500;600;700&family=JetBrains+Mono:wght@400;700&family=Space+Mono:wght@400;700&family=VT323&family=Press+Start+2P&family=Orbitron:wght@400;700;900&family=Rajdhani:wght@400;500;600;700&family=Oswald:wght@400;500;700&family=Bebas+Neue&family=Archivo+Black&family=Anton&family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Cinzel:wght@400;700;900&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Lora:ital,wght@0,400;0,700;1,400&family=Bangers&family=Bungee&family=Monoton&family=Audiowide&family=Special+Elite&family=Caveat:wght@400;700&family=Patrick+Hand&family=MedievalSharp&family=Major+Mono+Display&display=swap" rel="stylesheet">
<style>

:root{color-scheme:dark;}
body{margin:0;background:#0c0c0f;color:#e7e7ea;
  font-family:'Inter',system-ui,-apple-system,sans-serif;}
.topbar{position:sticky;top:0;z-index:50;background:#141417;
  border-bottom:1px solid #26262c;padding:12px 22px;
  display:flex;align-items:center;gap:18px;flex-wrap:wrap;}
.brand{font-weight:800;font-size:15px;letter-spacing:.3px;white-space:nowrap;}
.brand small{display:block;font-weight:500;font-size:11px;color:#8a8a93;letter-spacing:.2px;}
.counter{font-variant-numeric:tabular-nums;color:#8a8a93;font-size:13px;
  background:#1d1d22;border:1px solid #2a2a31;border-radius:8px;padding:5px 10px;white-space:nowrap;}
.meta{flex:1;min-width:240px;}
.meta-head{display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.meta-name{font-size:17px;font-weight:700;color:#fff;}
.cat-pill{font-size:11px;font-weight:600;color:#bdb4ff;background:#241f3d;
  border:1px solid #3a3260;border-radius:999px;padding:3px 10px;white-space:nowrap;}
.meta-desc{font-size:13px;line-height:1.5;color:#9a9aa3;margin-top:4px;max-width:760px;}
.ctrls{display:flex;align-items:center;gap:8px;}
.nav-btn{width:38px;height:38px;border-radius:9px;border:1px solid #2e2e36;
  background:#1d1d22;color:#e7e7ea;font-size:17px;cursor:pointer;
  display:flex;align-items:center;justify-content:center;transition:.15s;}
.nav-btn:hover{background:#27272e;border-color:#3a3a44;}
select{background:#1d1d22;color:#e7e7ea;border:1px solid #2e2e36;border-radius:9px;
  padding:9px 12px;font-size:14px;cursor:pointer;min-width:180px;font-family:inherit;}
.hint{color:#6a6a73;font-size:12px;text-align:center;padding:10px;}
.hint kbd{background:#1d1d22;border:1px solid #34343c;border-radius:5px;
  padding:1px 7px;font-family:inherit;font-size:11px;color:#b0b0b8;}
.viewport{padding:22px 22px 60px;max-width:1040px;margin:0 auto;}
.frame{border-radius:18px;overflow:hidden;border:1px solid #26262c;
  box-shadow:0 30px 80px rgba(0,0,0,.55);background:#000;}


*{box-sizing:border-box;}
.stage{--bg:#fff;--fg:#111;background:var(--bg);color:var(--fg);min-height:780px;
  border-radius:16px;overflow:hidden;position:relative;
  transition:background .45s ease,color .45s ease;
  font-family:system-ui,-apple-system,sans-serif;}
.stage .inner{padding:26px 32px 40px;max-width:940px;margin:0 auto;position:relative;z-index:1;}
.site-header{display:flex;align-items:center;justify-content:space-between;gap:20px;padding:14px 0 18px;}
.logo{font-size:22px;font-weight:800;letter-spacing:.5px;}
.nav{display:flex;gap:20px;font-size:14px;align-items:center;}
.nav a{cursor:pointer;opacity:.9;text-decoration:none;color:inherit;}
.cart{font-size:13px;padding:9px 15px;border:1px solid currentColor;border-radius:8px;white-space:nowrap;}
.hero{padding:44px 0 34px;}
.hero-title{font-size:40px;line-height:1.08;margin:0 0 12px;}
.hero-sub{font-size:16px;opacity:.82;margin:0 0 22px;max-width:540px;}
.hero-cta{padding:13px 28px;font-size:15px;cursor:pointer;border:none;font-weight:600;}
.section-title{font-size:24px;margin:32px 0 18px;}
.grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;align-items:start;}
.card{display:flex;flex-direction:column;gap:9px;padding:16px;}
.image{aspect-ratio:16/10;display:flex;align-items:center;justify-content:center;
  font-size:13px;text-align:center;position:relative;padding:6px;}
.platform{font-size:11px;letter-spacing:1.5px;opacity:.75;}
.title{font-size:16px;margin:0;}
.rating{font-size:13px;opacity:.85;}
.price-row{display:flex;align-items:baseline;gap:10px;margin-top:2px;}
.price-old{font-size:13px;opacity:.55;text-decoration:line-through;}
.price{font-size:22px;font-weight:800;line-height:1;}
.badge{position:absolute;top:8px;left:8px;font-size:12px;font-weight:700;padding:3px 9px;z-index:2;}
.btn-buy{margin-top:6px;padding:11px;cursor:pointer;border:none;font-size:14px;font-weight:600;}
.site-footer{margin-top:40px;padding:20px 0 4px;font-size:13px;opacity:.7;
  display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;}


.stage.theme-material{--bg:#f4f5f7;--fg:#1f2024;font-family:Roboto,system-ui,sans-serif;}
.theme-material .logo{color:#6200ea;font-weight:800;}
.theme-material .nav a{color:#5f6368;}
.theme-material .cart{border:none;background:#fff;box-shadow:0 1px 3px rgba(0,0,0,.2);border-radius:20px;color:#3c4043;}
.theme-material .hero{background:#fff;border-radius:8px;padding:42px 36px;box-shadow:0 1px 2px rgba(0,0,0,.15);}
.theme-material .hero-title{color:#202124;font-weight:500;}
.theme-material .hero-cta{background:#6200ea;color:#fff;border-radius:4px;text-transform:uppercase;letter-spacing:.8px;font-weight:600;box-shadow:0 1px 3px rgba(98,0,234,.5);}
.theme-material .card{background:#fff;border-radius:8px;box-shadow:0 1px 2px rgba(0,0,0,.12),0 1px 3px rgba(0,0,0,.18);}
.theme-material .card:hover{box-shadow:0 8px 16px rgba(0,0,0,.16);transform:translateY(-3px);}
.theme-material .image{background:#e8eaed;color:#9aa0a6;border-radius:6px 6px 0 0;margin:-16px -16px 0;}
.theme-material .platform{color:#6200ea;font-weight:700;}
.theme-material .price{color:#202124;}
.theme-material .badge{background:#6200ea;color:#fff;border-radius:4px;}
.theme-material .btn-buy{background:#6200ea;color:#fff;border-radius:4px;text-transform:uppercase;letter-spacing:.8px;box-shadow:0 1px 3px rgba(98,0,234,.4);}


.stage.theme-neumorph{--bg:#e0e5ec;--fg:#52606d;font-family:'Nunito',sans-serif;}
.theme-neumorph .logo{color:#5a6b7b;}
.theme-neumorph .cart{border:none;background:#e0e5ec;box-shadow:6px 6px 12px #b8bec7,-6px -6px 12px #ffffff;border-radius:14px;}
.theme-neumorph .hero{background:#e0e5ec;border-radius:24px;padding:40px;box-shadow:9px 9px 18px #b8bec7,-9px -9px 18px #ffffff;}
.theme-neumorph .hero-cta{background:#e0e5ec;color:#3b6fb0;border-radius:14px;box-shadow:6px 6px 12px #b8bec7,-6px -6px 12px #fff;font-weight:800;}
.theme-neumorph .card{background:#e0e5ec;border-radius:22px;box-shadow:9px 9px 18px #b8bec7,-9px -9px 18px #ffffff;}
.theme-neumorph .image{background:#e0e5ec;border-radius:14px;color:#9aa7b4;box-shadow:inset 6px 6px 12px #b8bec7,inset -6px -6px 12px #ffffff;}
.theme-neumorph .price{color:#41506b;}
.theme-neumorph .badge{background:#e0e5ec;color:#d05a5a;box-shadow:3px 3px 6px #b8bec7,-3px -3px 6px #fff;border-radius:10px;}
.theme-neumorph .btn-buy{background:#e0e5ec;color:#3b6fb0;border-radius:14px;box-shadow:6px 6px 12px #b8bec7,-6px -6px 12px #fff;font-weight:800;}
.theme-neumorph .btn-buy:active{box-shadow:inset 4px 4px 8px #b8bec7,inset -4px -4px 8px #fff;}


.stage.theme-glass{--bg:#0b1437;--fg:#eef2ff;font-family:Inter,system-ui,sans-serif;background:radial-gradient(circle at 20% 10%,#5b21b6,transparent 45%),radial-gradient(circle at 85% 30%,#0ea5e9,transparent 45%),radial-gradient(circle at 50% 90%,#db2777,transparent 50%),#0b1437;}
.theme-glass .logo{color:#fff;}
.theme-glass .nav a{color:#dbe3ff;}
.theme-glass .cart{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.3);backdrop-filter:blur(8px);border-radius:14px;color:#fff;}
.theme-glass .hero{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.25);backdrop-filter:blur(14px);border-radius:20px;padding:42px;box-shadow:0 8px 32px rgba(0,0,0,.3);}
.theme-glass .hero-cta{background:rgba(255,255,255,.2);border:1px solid rgba(255,255,255,.4);backdrop-filter:blur(8px);color:#fff;border-radius:12px;}
.theme-glass .card{background:rgba(255,255,255,.09);border:1px solid rgba(255,255,255,.2);backdrop-filter:blur(16px);border-radius:18px;box-shadow:0 8px 32px rgba(0,0,0,.25);}
.theme-glass .image{background:rgba(255,255,255,.07);border-radius:12px;color:#c7d2fe;border:1px solid rgba(255,255,255,.1);}
.theme-glass .price{color:#fff;}
.theme-glass .price-old{color:#b9c4e8;}
.theme-glass .badge{background:rgba(236,72,153,.85);color:#fff;border-radius:8px;backdrop-filter:blur(4px);}
.theme-glass .btn-buy{background:rgba(255,255,255,.18);border:1px solid rgba(255,255,255,.35);backdrop-filter:blur(8px);color:#fff;border-radius:12px;}
.theme-glass .site-footer{color:#cbd5f5;}


.stage.theme-clay{--bg:#eef1f8;--fg:#3a4a63;font-family:'Nunito',sans-serif;}
.theme-clay .logo{color:#3b82f6;font-weight:900;}
.theme-clay .cart{background:#fff;border:none;border-radius:18px;box-shadow:6px 6px 14px #d2d9ea,inset 3px 3px 6px #fff;color:#3b82f6;font-weight:800;}
.theme-clay .hero{background:#fff;border-radius:34px;padding:42px;box-shadow:12px 12px 26px #d2d9ea,-8px -8px 20px #fff,inset 4px 4px 10px rgba(255,255,255,.6);}
.theme-clay .hero-cta{background:#3b82f6;color:#fff;border-radius:22px;box-shadow:6px 6px 14px #a9c6f9,inset 3px 3px 8px rgba(255,255,255,.4);font-weight:900;}
.theme-clay .card{background:#fff;border-radius:30px;box-shadow:10px 10px 22px #d2d9ea,-6px -6px 16px #fff,inset 4px 4px 10px rgba(255,255,255,.5);}
.theme-clay .image{background:#ffe1e6;border-radius:22px;color:#ec4d6a;font-weight:900;box-shadow:inset 5px 5px 10px rgba(0,0,0,.05);}
.theme-clay .price{color:#2c3e63;font-weight:900;}
.theme-clay .badge{background:#34d399;color:#fff;border-radius:14px;box-shadow:3px 3px 8px rgba(52,211,153,.5);}
.theme-clay .btn-buy{background:#3b82f6;color:#fff;border-radius:20px;box-shadow:5px 5px 12px #a9c6f9,inset 3px 3px 8px rgba(255,255,255,.35);font-weight:900;}


.stage.theme-skeuo{--bg:#3a3a3c;--fg:#e8e4da;font-family:Georgia,'Times New Roman',serif;background:linear-gradient(180deg,#4a4a4c,#2e2e30);}
.theme-skeuo .inner{background:repeating-linear-gradient(45deg,#46443f,#46443f 2px,#423f3a 2px,#423f3a 4px);border:1px solid #222;box-shadow:inset 0 0 60px rgba(0,0,0,.5);}
.theme-skeuo .logo{color:#f2efe6;text-shadow:0 1px 0 #000,0 -1px 0 rgba(255,255,255,.3);}
.theme-skeuo .nav a{color:#d8d3c6;text-shadow:0 -1px 0 #000;}
.theme-skeuo .cart{background:linear-gradient(180deg,#6f6a5e,#4a463d);border:1px solid #2b2820;border-radius:8px;color:#fff;text-shadow:0 -1px 0 #000;box-shadow:inset 0 1px 0 rgba(255,255,255,.25);}
.theme-skeuo .hero{background:linear-gradient(180deg,#5b5750,#403d36);border:1px solid #211f1a;border-radius:10px;padding:38px;box-shadow:inset 0 1px 0 rgba(255,255,255,.2),0 4px 10px rgba(0,0,0,.5);}
.theme-skeuo .hero-cta{background:linear-gradient(180deg,#7fb3e6,#3a6fb0);border:1px solid #28527e;border-radius:8px;color:#fff;text-shadow:0 -1px 1px rgba(0,0,0,.5);box-shadow:inset 0 1px 0 rgba(255,255,255,.5);}
.theme-skeuo .card{background:linear-gradient(180deg,#efece2,#d8d3c4);border:1px solid #b3ad9c;border-radius:10px;box-shadow:inset 0 1px 0 #fff,0 5px 12px rgba(0,0,0,.5);color:#3a362c;}
.theme-skeuo .title,.theme-skeuo .rating,.theme-skeuo .platform{color:#3a362c;}
.theme-skeuo .image{background:linear-gradient(180deg,#fff,#cfcabb);border:1px solid #b0aa99;border-radius:6px;color:#8a8472;box-shadow:inset 0 2px 4px rgba(0,0,0,.15);}
.theme-skeuo .price{color:#2e7d32;text-shadow:0 1px 0 #fff;}
.theme-skeuo .price-old{color:#8a8472;}
.theme-skeuo .badge{background:linear-gradient(180deg,#ff7a7a,#c0392b);border:1px solid #8a2820;color:#fff;border-radius:6px;text-shadow:0 -1px 0 rgba(0,0,0,.4);}
.theme-skeuo .btn-buy{background:linear-gradient(180deg,#9fd86a,#5c9a2e);border:1px solid #3f6e1f;border-radius:8px;color:#fff;text-shadow:0 -1px 1px rgba(0,0,0,.4);box-shadow:inset 0 1px 0 rgba(255,255,255,.5);}
.theme-skeuo .site-footer{color:#cfcabb;}


.stage.theme-flat{--bg:#ecf0f1;--fg:#2c3e50;font-family:Roboto,system-ui,sans-serif;}
.theme-flat .logo{color:#1abc9c;font-weight:700;}
.theme-flat .nav a{color:#34495e;}
.theme-flat .cart{background:#1abc9c;border:none;border-radius:3px;color:#fff;}
.theme-flat .hero{background:#1abc9c;padding:42px;color:#fff;}
.theme-flat .hero-title{color:#fff;}.theme-flat .hero-sub{color:#e8fbf6;opacity:1;}
.theme-flat .hero-cta{background:#e67e22;color:#fff;border-radius:3px;}
.theme-flat .card{background:#fff;border-radius:3px;}
.theme-flat .image{background:#3498db;color:#fff;border-radius:0;margin:-16px -16px 0;}
.theme-flat .platform{color:#e67e22;font-weight:700;}
.theme-flat .price{color:#16a085;}
.theme-flat .badge{background:#e74c3c;color:#fff;border-radius:0;}
.theme-flat .btn-buy{background:#e67e22;color:#fff;border-radius:3px;}
.theme-flat .btn-buy:hover{background:#d35400;}


.stage.theme-saas{--bg:#f8fafc;--fg:#0f172a;font-family:Inter,system-ui,sans-serif;}
.theme-saas .logo{color:#0f172a;font-weight:800;letter-spacing:-.5px;}
.theme-saas .nav a{color:#475569;font-weight:500;}
.theme-saas .cart{background:#fff;border:1px solid #e2e8f0;border-radius:8px;color:#334155;font-weight:500;}
.theme-saas .hero{padding:50px 0 40px;}
.theme-saas .hero-title{color:#0f172a;font-weight:800;letter-spacing:-1px;}
.theme-saas .hero-sub{color:#64748b;}
.theme-saas .hero-cta{background:#4f46e5;color:#fff;border-radius:8px;font-weight:600;box-shadow:0 1px 2px rgba(79,70,229,.3);}
.theme-saas .card{background:#fff;border:1px solid #e2e8f0;border-radius:12px;box-shadow:0 1px 3px rgba(15,23,42,.06);}
.theme-saas .card:hover{box-shadow:0 10px 24px rgba(15,23,42,.08);border-color:#cbd5e1;}
.theme-saas .image{background:#f1f5f9;border-radius:8px;color:#94a3b8;}
.theme-saas .platform{color:#4f46e5;font-weight:600;}
.theme-saas .price{color:#0f172a;}
.theme-saas .badge{background:#10b981;color:#fff;border-radius:6px;}
.theme-saas .btn-buy{background:#0f172a;color:#fff;border-radius:8px;font-weight:600;}
.theme-saas .btn-buy:hover{background:#1e293b;}


.stage.theme-bento{--bg:#0f0f12;--fg:#f4f4f5;font-family:Inter,system-ui,sans-serif;}
.theme-bento .logo{color:#fafafa;font-weight:800;}
.theme-bento .nav a{color:#a1a1aa;}
.theme-bento .cart{background:#1c1c20;border:1px solid #2a2a30;border-radius:16px;color:#e4e4e7;}
.theme-bento .hero{background:linear-gradient(135deg,#1e1b4b,#312e81);border-radius:24px;padding:44px;}
.theme-bento .hero-title{color:#fff;font-weight:800;}
.theme-bento .hero-sub{color:#c7d2fe;}
.theme-bento .hero-cta{background:#fff;color:#1e1b4b;border-radius:14px;font-weight:700;}
.theme-bento .card{background:#1a1a1f;border:1px solid #27272e;border-radius:22px;padding:18px;}
.theme-bento .card:nth-child(1){background:linear-gradient(160deg,#1a1a1f,#231a2e);}
.theme-bento .card:nth-child(2){background:linear-gradient(160deg,#1a1a1f,#11242b);}
.theme-bento .card:nth-child(3){background:linear-gradient(160deg,#1a1a1f,#2b2411);}
.theme-bento .image{background:#0f0f12;border-radius:16px;color:#71717a;border:1px solid #27272e;}
.theme-bento .platform{color:#a78bfa;font-weight:600;}
.theme-bento .price{color:#fff;}
.theme-bento .price-old{color:#71717a;}
.theme-bento .badge{background:#fafafa;color:#0f0f12;border-radius:10px;}
.theme-bento .btn-buy{background:#fafafa;color:#0f0f12;border-radius:14px;font-weight:700;}
.theme-bento .site-footer{color:#71717a;}


.stage.theme-brutal{--bg:#fff;--fg:#000;font-family:'Courier New',monospace;}
.theme-brutal .inner{border:3px solid #000;}
.theme-brutal .logo{font-weight:700;text-transform:uppercase;}
.theme-brutal .nav a{text-decoration:underline;}
.theme-brutal .cart{border:3px solid #000;border-radius:0;color:#000;}
.theme-brutal .hero{border-bottom:3px solid #000;}
.theme-brutal .hero-title{font-weight:700;text-transform:uppercase;}
.theme-brutal .hero-cta{background:#000;color:#fff;border-radius:0;text-transform:uppercase;}
.theme-brutal .card{border:3px solid #000;}
.theme-brutal .image{border:3px solid #000;background:#fff;color:#000;text-transform:uppercase;font-weight:700;}
.theme-brutal .price{font-size:26px;border-bottom:4px solid #000;display:inline-block;}
.theme-brutal .badge{background:#000;color:#fff;border-radius:0;}
.theme-brutal .btn-buy{background:#000;color:#fff;border:3px solid #000;border-radius:0;text-transform:uppercase;}
.theme-brutal .btn-buy:hover{background:#fff;color:#000;}


.stage.theme-neobrutal{--bg:#ffe34d;--fg:#111;font-family:'Archivo Black','Arial Black',sans-serif;}
.theme-neobrutal .logo{background:#ff5470;color:#fff;border:3px solid #111;padding:4px 10px;box-shadow:4px 4px 0 #111;}
.theme-neobrutal .nav a{font-family:Inter,sans-serif;font-weight:700;color:#111;}
.theme-neobrutal .cart{background:#00e0c6;border:3px solid #111;border-radius:0;color:#111;box-shadow:4px 4px 0 #111;font-family:Inter,sans-serif;font-weight:800;}
.theme-neobrutal .hero{background:#a78bfa;border:3px solid #111;box-shadow:8px 8px 0 #111;padding:40px;}
.theme-neobrutal .hero-title{color:#111;text-transform:uppercase;}
.theme-neobrutal .hero-sub{color:#1a1a1a;font-family:Inter,sans-serif;font-weight:600;opacity:1;}
.theme-neobrutal .hero-cta{background:#ff5470;color:#fff;border:3px solid #111;box-shadow:5px 5px 0 #111;text-transform:uppercase;}
.theme-neobrutal .card{background:#fff;border:3px solid #111;box-shadow:7px 7px 0 #111;}
.theme-neobrutal .card:nth-child(2){background:#bdf25b;}
.theme-neobrutal .card:nth-child(3){background:#7ad7ff;}
.theme-neobrutal .image{background:#ffe34d;border:3px solid #111;color:#111;text-transform:uppercase;}
.theme-neobrutal .title,.theme-neobrutal .platform{font-family:Inter,sans-serif;font-weight:800;}
.theme-neobrutal .rating{font-family:Inter,sans-serif;}
.theme-neobrutal .price{color:#111;}
.theme-neobrutal .price-old{font-family:Inter,sans-serif;}
.theme-neobrutal .badge{background:#ff5470;color:#fff;border:2px solid #111;border-radius:0;}
.theme-neobrutal .btn-buy{background:#111;color:#fff;border:3px solid #111;box-shadow:4px 4px 0 #ff5470;text-transform:uppercase;}
.theme-neobrutal .btn-buy:active{transform:translate(4px,4px);box-shadow:0 0 0 #ff5470;}


.stage.theme-swiss{--bg:#fff;--fg:#111;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;}
.theme-swiss .inner{border-top:6px solid #e2231a;}
.theme-swiss .logo{color:#111;font-weight:700;letter-spacing:-1px;text-transform:uppercase;}
.theme-swiss .nav a{color:#111;text-transform:uppercase;font-size:12px;letter-spacing:1px;font-weight:700;}
.theme-swiss .cart{border:none;border-radius:0;background:#111;color:#fff;font-size:12px;text-transform:uppercase;}
